# ============================================
# KB라이프 보험 AI Agent - 환경변수 설정
# ============================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env

# OpenRouter API (LLM + 임베딩)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Anthropic API (insurance_tools 에서 사용)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Weaviate Cloud (벡터DB)
WEAVIATE_URL=https://xxxxx.weaviate.network
WEAVIATE_API_KEY=xxxxx

# Supabase (보험료 테이블)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxx
SUPABASE_KEY=eyJxxxxxxxxxx

# Next.js 프론트엔드
NEXT_PUBLIC_API_URL=http://localhost:8000
