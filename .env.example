# ============================================
# KB라이프 보험 AI Agent - 환경변수 설정
# ============================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env
#
# 배포 환경(Railway/Vercel)에서는 이 파일 대신
# 각 플랫폼의 대시보드에 동일한 변수들을 설정하세요.

# ─── 백엔드 (FastAPI) ─────────────────────────
# OpenRouter API (LLM + 임베딩)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Anthropic API (insurance_tools 에서 사용)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Weaviate Cloud (벡터DB)
WEAVIATE_URL=https://xxxxx.weaviate.network
WEAVIATE_API_KEY=xxxxx

# Supabase (보험료 테이블) — 백엔드 서버 사이드에서만 사용
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxxxxxx

# CORS 허용 도메인 (콤마 구분, 미설정시 * 허용)
# 배포시 예: CORS_ORIGINS=https://insurance-agent.vercel.app
CORS_ORIGINS=

# ─── 프론트엔드 (Next.js) ─────────────────────
# 서버사이드 API 라우트가 호출하는 백엔드 주소
# 로컬:    http://localhost:8000
# 배포시:  https://xxx.up.railway.app
BACKEND_URL=http://localhost:8000
