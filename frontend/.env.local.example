# ============================================
# Next.js 프론트엔드 환경변수 (Vercel 배포용)
# ============================================
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.local.example .env.local
#
# Vercel 배포 시에는 이 파일 대신
# Project → Settings → Environment Variables 에 동일하게 설정하세요.

# Next.js 서버사이드 API 라우트가 호출하는 백엔드 주소
# 로컬:    http://localhost:8000
# 배포시:  https://xxx.up.railway.app  (Railway 백엔드 URL)
BACKEND_URL=http://localhost:8000
